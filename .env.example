# listmonk app
LISTMONK_app__address=0.0.0.0:9000
LISTMONK_db__ssl_mode=require

# Optional first-run admin bootstrap.
# Set these only before the first successful install if you want to bootstrap
# the initial super admin non-interactively.
LISTMONK_ADMIN_USER=
LISTMONK_ADMIN_PASSWORD=

# Railway Postgres variables can be mapped directly, or translated to
# LISTMONK_db__* variables by the Dockerfile command.
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=

# Direct listmonk DB variables, if preferred.
LISTMONK_db__host=
LISTMONK_db__port=5432
LISTMONK_db__user=
LISTMONK_db__password=
LISTMONK_db__database=

# SendGrid SMTP values are configured inside the listmonk admin UI after boot.
# Host: smtp.sendgrid.net
# Port: 587
# Username: apikey
# Password: your SendGrid API key
